<h1>Edit Exercise</h1>

<form action="/exercises/<%= exercise._id %>?_method=PUT" method="POST">
    <label>Exercise Name:</label>
    <input type="text" name="exerciseName" value="<%= exercise.exerciseName %>">

    <label>Weight KG:</label>
    <input type="number" name="weight" value="<%= exercise.weight %>">

    <label>#Sets:</label>
    <input type="number" name="sets" value="<%= exercise.sets %>">

    <label>#Reps</label>
    <input type="number" name="reps" value="<%= exercise.reps %>">

    <button type="submit">Update Exercise</button>
</form>
